# --- Supabase (Project Settings -> API) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # chiave "service_role" (SEGRETA, solo server)

# --- Gemini (Google AI Studio -> Get API key) ---
GEMINI_API_KEY=AIza...
GEMINI_MODERATION_MODEL=gemini-2.5-flash-lite   # veloce/economico per moderare
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash          # per il report

# --- App ---
# Se l'AI non risponde (rate limit/errore): "open" pubblica e segnala, "closed" blocca tutto.
MODERATION_FAIL_MODE=open
# Sale segreto per anonimizzare gli IP (cambialo con una stringa casuale lunga)
IP_HASH_SALT=cambiami-con-una-stringa-casuale
# URL pubblico dell'app (per generare i link condivisibili)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
